{
  "name": "jesters-game-vault",
  "version": "0.1.11",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "A PS3-focused WinSCP-style FTP vault for owned backups and homebrew.",
  "author": "theJesterWins",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"wait-on http://127.0.0.1:5180 && npm run dev:electron\"",
    "dev:web": "vite --host 127.0.0.1",
    "dev:electron": "electron .",
    "build": "vite build",
    "pack:win": "npm run build && node scripts/package-win.cjs",
    "pack:linux": "npm run build && node scripts/package-linux.cjs",
    "sign:beta": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/sign-beta-exe.ps1",
    "zip:beta": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/create-beta-zip.ps1",
    "tar:linux": "bash scripts/create-linux-tarball.sh",
    "flatpak:bundle": "bash scripts/build-flatpak.sh",
    "dist:win": "npm run pack:win",
    "release:beta": "npm run lint && npm run pack:win && npm run sign:beta && npm run zip:beta",
    "release:linux": "npm run lint && npm run pack:linux && npm run tar:linux && JGV_SKIP_LINUX_PACKAGE=1 bash scripts/build-flatpak.sh",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "eslint ."
  },
  "dependencies": {
    "basic-ftp": "^5.0.5",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "electron": "^42.4.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.3",
    "vite": "^8.0.16",
    "wait-on": "^8.0.1"
  }
}
